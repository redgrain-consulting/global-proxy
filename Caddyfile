{
    debug

    servers {
        trusted_proxies static private_ranges
    }
}

(tls-config) {
    tls /etc/caddy/certs/local.crt /etc/caddy/certs/local.key
}

# Arguments: {args[0]} = container name
(laravel-vite) {
    # 1. Match ALL paths that must be served by the Vite Dev Server (Port 5173)
    @vite {
        path /@vite-hmr* /@vite/* /@id/* /@fs/* /resources/* /node_modules/* /vendor/statamic/cp/build/*
    }

    handle @vite {
        # Check if this specific request is a WebSocket upgrade attempt
        @isWS {
            header Connection *Upgrade*
            header Upgrade    websocket
        }

        # If it's a WebSocket (HMR), force the Upgrade headers
        handle @isWS {
            reverse_proxy {args[0]}:5173 {
                header_up Host {host}
                header_up Origin {>Origin}
                header_up X-Real-IP {remote}
                header_up Connection "Upgrade"
                header_up Upgrade "websocket"
            }
        }

        # For standard GET requests (assets, node_modules), proxy WITHOUT Upgrade headers
        handle {
            reverse_proxy {args[0]}:5173 {
                header_up Host {host}
                header_up Origin {>Origin}
                header_up X-Real-IP {remote}
            }
        }
    }

    # 2. Route all other traffic (PHP/Statamic) to Nginx (Port 80)
    handle {
        reverse_proxy {args[0]}:80 {
            header_up Host {host}
            header_up X-Real-IP {remote}
            header_up X-Forwarded-Proto https
        }
    }
}

# Arguments: {args[0]} = container name
(turbo) {
	reverse_proxy {args[0]}:3000 {
        header_up Host {host}
        header_up Origin {>Origin}
        header_up X-Real-IP {remote}
        
        # Required for Next.js Fast Refresh (WebSockets)
        header_up Connection {>Connection}
        header_up Upgrade {>Upgrade}
    }
}

(react-router-v7) {
    # Match only WebSocket-specific paths
    @websockets {
        header Connection *Upgrade*
        header Upgrade    websocket
        path /@vite-hmr*
    }

    handle @websockets {
        # CHANGE 3000 TO THE ACTUAL PORT FOUND IN hydrogen.log
        reverse_proxy {args[0]}:3000 { 
            header_up Host {host}
            header_up Origin {>Origin}
            header_up X-Real-IP {remote}
            header_up Connection "Upgrade"
            header_up Upgrade "websocket"
        }
    }

    handle {
        # CHANGE 3000 TO THE ACTUAL PORT
        reverse_proxy {args[0]}:3000 { 
            header_up Host {host}
            header_up Origin {>Origin}
            header_up X-Real-IP {remote}
        }
    }
}

(storybook) {
    # Added /@id/* and /@fs/* to support Vite virtual modules
    @storybookWS {
        header Connection *Upgrade*
        header Upgrade    websocket
        path /storybook-server-channel* /@vite-hmr* /@vite/* /@id/* /@fs/* /virtual:/*
    }

    handle @storybookWS {
        reverse_proxy https://{args[0]}:6006 {
            header_up Host {host}
            header_up Origin {>Origin}
            header_up X-Real-IP {remote}
            header_up Connection "Upgrade"
            header_up Upgrade "websocket"
            
            transport http {
                tls_insecure_skip_verify 
            }
        }
    }

    handle {
        reverse_proxy https://{args[0]}:6006 {
            header_up Host {host}
            header_up Origin {>Origin}
            header_up X-Real-IP {remote}
            
            transport http {
                tls_insecure_skip_verify 
            }
        }
    }
}

