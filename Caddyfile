*.dev.redgrain.co.uk:6006 {
	import tls-config

    # Use a wildcard host matcher for the whole block to ensure 
    # no assets (even ones with the port) are rejected.
    @storybook-hosts host caffenero.dev.redgrain.co.uk:6006 caffenero-website-catalyst.dev.redgrain.co.uk:6006 caffenero-website-hydrogen.dev.redgrain.co.uk:6006 caffenero-statamic.dev.redgrain.co.uk:6006 coffee1-website.dev.redgrain.co.uk:6006 harrisandhoole.dev.redgrain.co.uk:6006

	@caffenero header_regexp Host ^caffenero\.dev\.redgrain\.co\.uk(:6006)?$
	handle @caffenero {
		import storybook caffenero
	}

	@caffenero-statamic header_regexp Host ^caffenero-statamic\.dev\.redgrain\.co\.uk(:6006)?$
